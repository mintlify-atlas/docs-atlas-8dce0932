  "keyFeatures": [
    "JWT authentication with four role levels: read, write, admin, root",
    "Vehicle management with automatic odometer tracking via atomic $inc operations",
    "Trip/route logging that updates vehicle total kilometrage in real time",
    "Fuel refuel tracking with km/liter, km/gallon, and cost-per-km efficiency analytics",
    "Preventive maintenance scheduling with date and mileage-based alerts",
    "Vehicle expense tracking with recurring expenses and tax-deductible flags",
    "Comprehensive cost-of-ownership statistics and per-vehicle analytics",
    "Rate limiting (100 req/15min general, 5 req/15min auth) and request tracing",
    "Pagination on all list endpoints",
    "Soft delete for users and vehicles; permanent delete for transactional records"
  ],
